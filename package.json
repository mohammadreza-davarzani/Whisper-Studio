{
  "name": "whisper-studio",
  "version": "0.1.18",
  "description": "Open-source Electron, React, and TypeScript desktop boilerplate for Whisper Studio.",
  "author": {
    "name": "Whisper Studio Contributors",
    "email": "mha.karimi@gmail.com"
  },
  "license": "MIT",
  "private": false,
  "main": "./out/main/index.cjs",
  "type": "module",
  "scripts": {
    "dev": "node scripts/electron-vite.mjs dev",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "prepare-icons": "node scripts/generate-icons.mjs",
    "build": "npm run typecheck && electron-vite build",
    "preview": "node scripts/electron-vite.mjs preview",
    "pack": "npm run prepare-icons && npm run build && electron-builder --dir",
    "dist": "npm run prepare-icons && npm run build && electron-builder",
    "dist:mac": "npm run prepare-icons && npm run build && electron-builder --mac",
    "dist:win": "npm run prepare-icons && npm run build && electron-builder --win",
    "dist:linux": "npm run prepare-icons && npm run build && electron-builder --linux",
    "lint": "eslint .",
    "format": "prettier --write .",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "runtime:build": "node scripts/runtime/build-runtime.mjs",
    "runtime:manifest": "node scripts/runtime/create-manifest.mjs"
  },
  "dependencies": {
    "@fontsource/inter": "^5.1.0",
    "@radix-ui/react-checkbox": "^1.3.5",
    "@radix-ui/react-slot": "^1.3.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "extract-zip": "^2.0.1",
    "lucide-react": "^0.468.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "tailwind-merge": "^3.6.0",
    "tw-animate-css": "^1.4.0"
  },
  "devDependencies": {
    "@electron-toolkit/preload": "^3.0.1",
    "@electron-toolkit/tsconfig": "^1.0.1",
    "@tailwindcss/vite": "^4.3.1",
    "@types/archiver": "^6.0.4",
    "@types/node": "^22.10.2",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.4",
    "@vitest/coverage-v8": "^4.1.9",
    "archiver": "^7.0.1",
    "electron": "^33.2.1",
    "electron-builder": "^25.1.8",
    "electron-vite": "^2.3.0",
    "esbuild": "^0.28.1",
    "eslint": "^9.16.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-react-hooks": "^5.1.0",
    "prettier": "^3.4.2",
    "sharp": "^0.35.3",
    "tailwindcss": "^4.3.1",
    "typescript": "^5.7.2",
    "typescript-eslint": "^8.18.2",
    "vite": "^5.4.11",
    "vitest": "^4.1.9"
  },
  "build": {
    "appId": "dev.whisperstudio.desktop",
    "productName": "WhisperStudio",
    "copyright": "Copyright © 2026 WhisperStudio Contributors",
    "directories": {
      "output": "release",
      "buildResources": "resources"
    },
    "files": [
      "out/**/*",
      "resources/**/*",
      "package.json"
    ],
    "icon": "icon.png",
    "asar": true,
    "publish": [
      {
        "provider": "github",
        "releaseType": "release"
      }
    ],
    "mac": {
      "category": "public.app-category.productivity",
      "icon": "icon.icns",
      "target": [
        "dmg",
        "zip"
      ]
    },
    "win": {
      "icon": "icon.ico",
      "target": [
        "nsis",
        "portable"
      ]
    },
    "linux": {
      "category": "Utility",
      "icon": "icons",
      "maintainer": "Whisper Studio Contributors <contributors@whisperstudio.dev>",
      "target": [
        "AppImage",
        "deb"
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true
    }
  }
}
